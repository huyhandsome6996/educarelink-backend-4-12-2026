{
  "expo": {
    "name": "EduCareLink",
    "slug": "educarelink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#F26522",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.educarelink.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#F26522"
      },
      "package": "com.educarelink.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "EduCareLink cần truy cập ảnh để tải lên CCCD và ảnh chân dung.",
          "cameraPermission": "EduCareLink cần camera để chụp ảnh CCCD và chân dung."
        }
      ],
      "expo-notifications"
    ]
  }
}
