# ════════════════════════════════════════════════════════════════════
# EduCareLink — Sample Environment Variables
# Copy to .env và điền giá trị thực. KHÔNG commit .env lên git.
# ════════════════════════════════════════════════════════════════════

# --- Django core ---
DEBUG=True
SECRET_KEY=django-insecure-dev-only-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
RENDER=false
CORS_ALLOW_ALL_ORIGINS=True

# --- Database (chỉ cần khi DEBUG=False / production) ---
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- AI ---
GEMINI_API_KEY=

# --- Keep-Alive scheduler ---
KEEPALIVE_ENABLED=false

# ════════════════════════════════════════════════════════════════════
# MoMo Payment — ĐÃ TẮT (chuyển sang PayOS)
# ════════════════════════════════════════════════════════════════════
# MoMo code vẫn giữ trong repo (backward compatibility) nhưng KHÔNG cấu hình.
# Để bật lại MoMo: set 3 biến bên dưới + MOMO_ENVIRONMENT=sandbox
# MOMO_ENVIRONMENT=sandbox
# MOMO_PARTNER_CODE=
# MOMO_ACCESS_KEY=
# MOMO_SECRET_KEY=
# MOMO_STORE_ID=
# MOMO_RETURN_BASE_URL=http://localhost:8000
# MOMO_IPN_URL=http://localhost:8000/api/payments/momo-ipn/

# ════════════════════════════════════════════════════════════════════
# PayOS Payment (VietQR bank transfer — MIỄN PHÍ 100%)
# ════════════════════════════════════════════════════════════════════
# Đăng ký tại https://my.payos.vn/register (cá nhân — chỉ cần CCCD)
# Lấy 3 keys: Client ID, API Key, Checksum Key
# PAYOS_CLIENT_ID=
# PAYOS_API_KEY=
# PAYOS_CHECKSUM_KEY=
# PAYOS_RETURN_BASE_URL=http://localhost:8000
# PAYOS_WEBHOOK_URL=http://localhost:8000/api/payments/payos-webhook/

# Tỷ lệ hoa hồng nền tảng (20% mặc định)
PAYMENT_COMMISSION_RATE=0.20

# Số ngày Carepartner có để quét QR thanh toán hoa hồng
PAYMENT_SETTLEMENT_DUE_DAYS=7

# Monthly settlement scheduler (chỉ chạy trên Render/production)
PAYMENT_SCHEDULER_ENABLED=false

# ════════════════════════════════════════════════════════════════════
# DEVICE OFFLINE ALERT (chống tắt máy/đập máy để phạm tội)
# ════════════════════════════════════════════════════════════════════
# Carepartner app gửi heartbeat mỗi 30s
TRACKING_HEARTBEAT_INTERVAL=30

# Ngưỡng phát hiện offline: nếu last_seen > 60s = 2 lần miss (safety audit recommendation)
TRACKING_OFFLINE_THRESHOLD=60

# Bật/tắt offline check scheduler (chỉ chạy trên Render)
TRACKING_OFFLINE_CHECK_ENABLED=true

# Tần suất check offline (phút) — mặc định 1 phút
TRACKING_OFFLINE_CHECK_INTERVAL=1
