# ════════════════════════════════════════════════════════════════════
# EduCareLink — Sample Environment Variables
# Copy to .env và điền giá trị thực. KHÔNG commit .env lên git.
# ════════════════════════════════════════════════════════════════════

# --- Django core ---
DEBUG=True
SECRET_KEY=django-insecure-dev-only-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
RENDER=false
CORS_ALLOW_ALL_ORIGINS=True

# --- Database (chỉ cần khi DEBUG=False / production) ---
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- AI ---
GEMINI_API_KEY=

# --- Keep-Alive scheduler ---
KEEPALIVE_ENABLED=true

# ════════════════════════════════════════════════════════════════════
# MoMo Payment (thêm bởi module payments)
# ════════════════════════════════════════════════════════════════════

# Environment: sandbox (test) | production (live)
MOMO_ENVIRONMENT=sandbox

# ── Sandbox test credentials (từ repo chính thức momo-wallet/payment) ──
# Repo: https://github.com/momo-wallet/payment/blob/master/python/MoMo.py
# Đã verify hoạt động 2026-06-17 (trả resultCode=0 + payUrl)
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=F8BBA842ECF85
MOMO_SECRET_KEY=K951B6PE1waDMi640xX08PD3vg6EkVlz
MOMO_STORE_ID=EduCareLinkStore

# ── Production credentials (điền khi go-live) ──
# Đăng ký đối tác tại: https://business.momo.vn/
# MOMO_PARTNER_CODE=<production_partner_code>
# MOMO_ACCESS_KEY=<production_access_key>
# MOMO_SECRET_KEY=<production_secret_key>

# URL MoMo redirect browser về sau khi user pay xong
# Phải là domain công khai có thể truy cập từ internet
MOMO_RETURN_BASE_URL=http://localhost:8000

# IPN URL — MoMo gọi server-to-server khi giao dịch hoàn tất
# Khi test local: dùng ngrok / cloudflared tunnel để public localhost
MOMO_IPN_URL=http://localhost:8000/api/payments/momo-ipn/

# Tỷ lệ hoa hồng nền tảng (20% mặc định)
PAYMENT_COMMISSION_RATE=0.20

# Số ngày Carepartner có để quét QR thanh toán hoa hồng
PAYMENT_SETTLEMENT_DUE_DAYS=7

# Monthly settlement scheduler (chỉ chạy trên Render/production)
PAYMENT_SCHEDULER_ENABLED=false

# ════════════════════════════════════════════════════════════════════
# DEVICE OFFLINE ALERT (chống tắt máy/đập máy để phạm tội)
# ════════════════════════════════════════════════════════════════════
# Carepartner app gửi heartbeat mỗi 30s
TRACKING_HEARTBEAT_INTERVAL=30

# Ngưỡng phát hiện offline: nếu last_seen > 90s = 3 lần miss = chắc chắn tắt máy
TRACKING_OFFLINE_THRESHOLD=90

# Bật/tắt offline check scheduler (chỉ chạy trên Render)
TRACKING_OFFLINE_CHECK_ENABLED=true

# Tần suất check offline (phút) — mặc định 1 phút
TRACKING_OFFLINE_CHECK_INTERVAL=1
